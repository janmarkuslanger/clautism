# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# --- Telegram (user API via Telethon) ---
# Get api_id and api_hash at https://my.telegram.org → API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=          # your number in international format, e.g. +4917612345678
TELEGRAM_SESSION=telegram_session   # path to the session file (created on first run)

# --- Ollama ---
# OLLAMA_HOST=http://localhost:11434
# BIRTHDAY_MODEL=qwen2.5

# --- App ---
# BIRTHDAY_PEOPLE_FILE=data/people.json
# BIRTHDAY_STATE_DIR=.stagehand/runs
# BIRTHDAY_DRY_RUN=1     # uncomment to route all messages to the console
# BIRTHDAY_DATE=2026-01-01  # override today's date (for testing)
